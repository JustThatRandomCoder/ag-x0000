---
export interface Props {
  audioSrc: string;
  title: string;
  duration?: string;
  className?: string;
}

const { audioSrc, title, duration = "00:00", className = "" } = Astro.props;
---

<div class={`modern-audio-player ${className}`}>
  <div class="audio-header">
    <h4 class="audio-title">{title}</h4>
    <span class="audio-duration">{duration}</span>
  </div>
  
  <audio class="audio-element" preload="metadata">
    <source src={audioSrc} type="audio/mpeg" />
    <source src={audioSrc.replace('.mp3', '.ogg')} type="audio/ogg" />
    Ihr Browser unterstützt das Audio-Element nicht.
  </audio>
  
  <div class="player-controls">
    <button class="control-btn rewind-btn" title="15s zurück">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
        <path d="M3 3v5h5" />
        <text x="12" y="16" font-size="6" text-anchor="middle" fill="currentColor">15</text>
      </svg>
    </button>
    
    <button class="control-btn play-pause-btn" title="Play/Pause">
      <svg class="play-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
        <path d="M8 5v14l11-7z" />
      </svg>
      <svg class="pause-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" style="display: none;">
        <path d="M6 19h4V5H6v14zM14 5v14h4V5h-4z" />
      </svg>
    </button>
    
    <button class="control-btn forward-btn" title="15s vor">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 12a9 9 0 1 1-9-9c.75 0 1.5.09 2.2.26l1.8-1.8" />
        <path d="M21 3v5h-5" />
        <text x="12" y="16" font-size="6" text-anchor="middle" fill="currentColor">15</text>
      </svg>
    </button>
  </div>
  
  <div class="progress-container">
    <div class="progress-bar">
      <div class="progress-track">
        <div class="progress-fill"></div>
        <div class="progress-handle"></div>
      </div>
    </div>
    <div class="time-display">
      <span class="current-time">0:00</span>
      <span class="total-time">{duration}</span>
    </div>
  </div>
</div>

<style>
  .modern-audio-player {
    background: var(--background-50);
    border: 1px solid var(--background-200);
    border-radius: 16px;
    padding: 20px;
    margin: 16px 0;
    transition: all 0.3s ease;
  }
  
  .modern-audio-player:hover {
    border-color: var(--primary-300);
    transform: translateY(-2px);
  }
  
  .audio-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }
  
  .audio-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-800);
    margin: 0;
  }
  
  .audio-duration {
    font-size: 0.9rem;
    color: var(--text-500);
    font-weight: 500;
  }
  
  .player-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 20px;
  }
  
  .control-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-600);
    transition: all 0.2s ease;
    padding: 8px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .control-btn:hover {
    color: var(--primary);
    background: var(--background-100);
  }
  
  .play-pause-btn {
    background: var(--primary);
    color: white;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    margin: 0 8px;
  }
  
  .play-pause-btn:hover {
    background: var(--primary-600);
    transform: scale(1.05);
  }
  
  .progress-container {
    width: 100%;
  }
  
  .progress-bar {
    margin-bottom: 8px;
  }
  
  .progress-track {
    position: relative;
    height: 6px;
    background: var(--background-200);
    border-radius: 3px;
    cursor: pointer;
    overflow: hidden;
  }
  
  .progress-fill {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    background: var(--primary);
    border-radius: 3px;
    width: 0%;
    transition: width 0.1s ease;
  }
  
  .progress-handle {
    position: absolute;
    top: 50%;
    left: 0%;
    transform: translate(-50%, -50%);
    width: 16px;
    height: 16px;
    background: var(--primary);
    border-radius: 50%;
    opacity: 0;
    transition: opacity 0.2s ease;
    cursor: grab;
  }
  
  .progress-track:hover .progress-handle {
    opacity: 1;
  }
  
  .progress-handle:active {
    cursor: grabbing;
    transform: translate(-50%, -50%) scale(1.2);
  }
  
  .time-display {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    color: var(--text-500);
    font-weight: 500;
  }
  
  .audio-element {
    display: none;
  }
  
  /* Dark Mode Anpassungen */
  :root[data-theme="dark"] .modern-audio-player {
    background: var(--background-100);
    border-color: var(--background-300);
  }
  
  :root[data-theme="dark"] .modern-audio-player:hover {
    border-color: var(--primary-500);
  }
  
  /* Mobile Optimierungen */
  @media (max-width: 768px) {
    .modern-audio-player {
      padding: 16px;
    }
    
    .audio-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }
    
    .control-btn {
      padding: 12px;
    }
    
    .play-pause-btn {
      width: 52px;
      height: 52px;
    }
  }
</style>
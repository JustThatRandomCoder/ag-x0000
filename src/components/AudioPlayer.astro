---
export interface Props {
  audioSrc: string;
  title: string;
  duration?: string;
  className?: string;
}

const { audioSrc, title, duration = "00:00", className = "" } = Astro.props;
---

<div class={`modern-audio-player ${className}`}>
  <div class="audio-header">
    <h4 class="audio-title">{title}</h4>
    <span class="audio-duration">{duration}</span>
  </div>

  <audio class="audio-element" preload="metadata" playsinline src={audioSrc}>
    Ihr Browser unterstützt das Audio-Element nicht.
  </audio>

  <div class="player-controls">
    <button class="control-btn rewind-btn" title="15s zurück" aria-label="15 Sekunden zurück">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
        <path d="M3 3v5h5"></path>
        <text x="12" y="16" font-size="6" text-anchor="middle" fill="currentColor">15</text>
      </svg>
    </button>

    <button class="control-btn play-pause-btn" title="Play/Pause" aria-label="Wiedergabe starten oder pausieren">
      <svg
        class="play-icon"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path d="M8 5v14l11-7z"></path>
      </svg>
      <svg
        class="pause-icon"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path d="M6 19h4V5H6v14zM14 5v14h4V5h-4z"></path>
      </svg>
    </button>

    <button class="control-btn forward-btn" title="15s vor" aria-label="15 Sekunden vor">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M21 12a9 9 0 1 1-9-9c.75 0 1.5.09 2.2.26l1.8-1.8"></path>
        <path d="M21 3v5h-5"></path>
        <text x="12" y="16" font-size="6" text-anchor="middle" fill="currentColor">15</text>
      </svg>
    </button>
  </div>

  <div class="progress-container">
    <input
      class="progress-range"
      type="range"
      min="0"
      max="100"
      step="0.1"
      value="0"
      aria-label="Audio-Position"
    />
    <div class="time-display">
      <span class="current-time">0:00</span>
      <span class="total-time">{duration}</span>
    </div>
  </div>
</div>

<style>
  .modern-audio-player {
    background: var(--bg-muted);
    border: 0.0625rem solid var(--border);
    border-radius: 1rem;
    padding: 1rem;
  }

  .audio-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.9rem;
  }

  .audio-title {
    margin: 0;
    font-size: 0.96rem;
    font-weight: 560;
    color: var(--text);
  }

  .audio-duration {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .player-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.62rem;
    margin-bottom: 0.9rem;
  }

  .control-btn {
    background: var(--bg-elevated);
    border: 0.0625rem solid var(--border);
    cursor: pointer;
    color: var(--text);
    transition: transform 0.2s ease, border-color 0.2s ease;
    border-radius: 0.75rem;
    inline-size: 2.3rem;
    block-size: 2.3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .control-btn:hover {
    border-color: var(--accent);
    transform: translateY(-0.08rem);
  }

  .play-pause-btn {
    background: linear-gradient(135deg, var(--accent), var(--accent-strong));
    color: #111111;
    inline-size: 3rem;
    block-size: 3rem;
    border-radius: 50%;
    border: 0;
    box-shadow: 0 0.6rem 1.2rem rgba(0, 0, 0, 0.32);
  }

  .play-pause-btn:hover {
    transform: translateY(-0.09rem) scale(1.02);
  }

  .pause-icon {
    display: none;
  }

  .progress-container {
    width: 100%;
  }

  .progress-range {
    --progress: 0%;
    appearance: none;
    width: 100%;
    height: 0.35rem;
    border-radius: 999rem;
    background: linear-gradient(
      to right,
      var(--accent) 0%,
      var(--accent) var(--progress),
      var(--bg-elevated) var(--progress),
      var(--bg-elevated) 100%
    );
    border: 0.0625rem solid var(--border);
    cursor: pointer;
    margin: 0;
  }

  .progress-range::-webkit-slider-thumb {
    appearance: none;
    inline-size: 0.85rem;
    block-size: 0.85rem;
    border-radius: 50%;
    border: 0;
    background: var(--accent-strong);
    box-shadow: 0 0 0 0.125rem color-mix(in oklab, var(--accent) 35%, transparent);
  }

  .progress-range::-moz-range-thumb {
    inline-size: 0.85rem;
    block-size: 0.85rem;
    border-radius: 50%;
    border: 0;
    background: var(--accent-strong);
  }

  .time-display {
    display: flex;
    justify-content: space-between;
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .audio-element {
    display: none;
  }

  @media (max-width: 48rem) {
    .audio-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll(".modern-audio-player").forEach((playerContainer) => {
      const audio = playerContainer.querySelector(".audio-element");
      const playPauseBtn = playerContainer.querySelector(".play-pause-btn");
      const playIcon = playerContainer.querySelector(".play-icon");
      const pauseIcon = playerContainer.querySelector(".pause-icon");
      const rewindBtn = playerContainer.querySelector(".rewind-btn");
      const forwardBtn = playerContainer.querySelector(".forward-btn");
      const progressRange = playerContainer.querySelector(".progress-range");
      const currentTimeSpan = playerContainer.querySelector(".current-time");
      const totalTimeSpan = playerContainer.querySelector(".total-time");
      const audioDurationLabel = playerContainer.querySelector(".audio-duration");

      if (
        !audio ||
        !playPauseBtn ||
        !playIcon ||
        !pauseIcon ||
        !rewindBtn ||
        !forwardBtn ||
        !progressRange ||
        !currentTimeSpan ||
        !totalTimeSpan ||
        !audioDurationLabel
      ) {
        return;
      }

      let isSeeking = false;

      function formatTime(seconds) {
        if (!Number.isFinite(seconds)) return "0:00";
        const mins = Math.floor(seconds / 60);
        const secs = Math.floor(seconds % 60);
        return `${mins}:${secs.toString().padStart(2, "0")}`;
      }

      function setPlayingState(isPlaying) {
        playIcon.style.display = isPlaying ? "none" : "block";
        pauseIcon.style.display = isPlaying ? "block" : "none";
      }

      function setProgress(progressPercent) {
        const safe = Math.max(0, Math.min(100, progressPercent));
        progressRange.value = String(safe);
        progressRange.style.setProperty("--progress", `${safe}%`);
      }

      function syncDuration() {
        if (!Number.isFinite(audio.duration) || audio.duration <= 0) {
          return;
        }
        const formatted = formatTime(audio.duration);
        totalTimeSpan.textContent = formatted;
        audioDurationLabel.textContent = formatted;
      }

      function clearErrorState() {
        if (audioDurationLabel.textContent === "Fehler") {
          audioDurationLabel.textContent = "--:--";
        }
      }

      function commitSeek() {
        if (Number.isFinite(audio.duration) && audio.duration > 0) {
          audio.currentTime = (Number(progressRange.value) / 100) * audio.duration;
        }
        isSeeking = false;
      }

      audio.addEventListener("loadedmetadata", function () {
        clearErrorState();
        syncDuration();
      });
      audio.addEventListener("durationchange", syncDuration);
      audio.addEventListener("loadeddata", syncDuration);
      audio.addEventListener("canplay", syncDuration);

      audio.addEventListener("timeupdate", function () {
        if (!isSeeking && Number.isFinite(audio.duration) && audio.duration > 0) {
          const progress = (audio.currentTime / audio.duration) * 100;
          setProgress(progress);
          currentTimeSpan.textContent = formatTime(audio.currentTime);
        }
      });

      playPauseBtn.addEventListener("click", function () {
        if (audio.paused) {
          audio.play().catch(() => undefined);
          setPlayingState(true);
        } else {
          audio.pause();
          setPlayingState(false);
        }
      });

      rewindBtn.addEventListener("click", function () {
        audio.currentTime = Math.max(0, audio.currentTime - 15);
      });

      forwardBtn.addEventListener("click", function () {
        if (Number.isFinite(audio.duration)) {
          audio.currentTime = Math.min(audio.duration, audio.currentTime + 15);
        }
      });

      progressRange.addEventListener("input", function () {
        isSeeking = true;
        const progress = Number(progressRange.value);
        setProgress(progress);

        if (Number.isFinite(audio.duration) && audio.duration > 0) {
          const previewTime = (progress / 100) * audio.duration;
          currentTimeSpan.textContent = formatTime(previewTime);
        }
      });

      progressRange.addEventListener("change", commitSeek);
      progressRange.addEventListener("pointerdown", function () {
        isSeeking = true;
      });
      progressRange.addEventListener("pointerup", commitSeek);
      progressRange.addEventListener("touchend", commitSeek);
      progressRange.addEventListener("keyup", function (event) {
        if (
          event.key === "ArrowLeft" ||
          event.key === "ArrowRight" ||
          event.key === "Home" ||
          event.key === "End"
        ) {
          commitSeek();
        }
      });

      audio.addEventListener("play", function () {
        setPlayingState(true);
      });

      audio.addEventListener("pause", function () {
        setPlayingState(false);
      });

      audio.addEventListener("ended", function () {
        setPlayingState(false);
        setProgress(0);
        currentTimeSpan.textContent = "0:00";
      });

      audio.addEventListener("error", function () {
        audioDurationLabel.textContent = "Fehler";
        totalTimeSpan.textContent = "--:--";
        currentTimeSpan.textContent = "0:00";
        setPlayingState(false);
      });

      setPlayingState(false);
      setProgress(0);
      if (audio.readyState >= 1) {
        syncDuration();
      }
    });
  });
</script>

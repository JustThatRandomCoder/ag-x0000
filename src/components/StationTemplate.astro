---
export interface Props {
  stationNumber: number;
  title: string;
  description: string;
  audioFile: string;
  locationInfo: string;
}

const { stationNumber, title, description, audioFile, locationInfo } =
  Astro.props;

import Layout from "./Layout.astro";
import AudioPlayer from "./AudioPlayer.astro";
import { getNextStation, getPreviousStation } from "../routes/router.ts";

const nextStation = getNextStation(stationNumber);
const previousStation = getPreviousStation(stationNumber);
---

<Layout title={title} description={description}>
  <main class="station-page">
    <div class="container">
      <!-- Station Header -->
      <header class="station-header">
        <div class="station-breadcrumb">
          <a href="/">🏛️ Agora Audioführung</a>
          <span class="breadcrumb-separator">→</span>
          <span class="current-station">Station {stationNumber}</span>
        </div>

        <div class="station-info">
          <div class="station-number">Station {stationNumber}</div>
          <h1 class="station-title-left">
            {title.replace(`Station ${stationNumber}: `, "")}
          </h1>
          <p class="station-description">{description}</p>
        </div>
      </header>

      <!-- Audio Player Section -->
      <section class="audio-section">
        <div class="audio-container">
          <div class="audio-intro">
            <h2>🎧 Audioführung</h2>
            <p>
              Lauschen Sie der historischen Erzählung über diesen bedeutenden
              Ort
            </p>
          </div>

          <AudioPlayer
            audioSrc={audioFile}
            title={"Station " + stationNumber + ": Audio-Guide"}
            duration="3:45"
            className="station-audio-player"
          />
        </div>
      </section>

      <!-- Content Sections - Simplified Layout -->
      <div class="content-vertical">
        <!-- Beschreibung -->
        <section class="content-section">
          <h3>📜 Beschreibung</h3>
          <div class="content-text">
            {description}
          </div>
        </section>

        <!-- Ort -->
        <section class="content-section">
          <h3>📍 Ort</h3>
          <div class="content-text">
            {locationInfo}
          </div>
        </section>

        <!-- Eckdaten -->
        <section class="content-section">
          <h3>⚙️ Eckdaten</h3>
          <div class="content-text">
            <strong>Periode:</strong> 6. Jahrhundert v. Chr. - 6. Jahrhundert n. Chr.<br
            />
            <strong>Funktion:</strong>
            {title.replace(`Station ${stationNumber}: `, "").toLowerCase()}<br
            />
            <strong>Erhaltung:</strong> Archäologische Überreste<br />
            <strong>Bedeutung:</strong> Zentrum der athenischen Demokratie
          </div>
        </section>
      </div>

      <!-- Navigation -->
      <nav class="station-navigation">
        <div class="nav-container">
          {
            previousStation && (
              <a href={previousStation.path} class="nav-btn nav-prev">
                <span class="nav-direction">← Vorherige Station</span>
                <span class="nav-title">
                  {previousStation.title.replace(
                    `Station ${previousStation.stationNumber}: `,
                    "",
                  )}
                </span>
              </a>
            )
          }

          <a href="/" class="nav-btn nav-home">
            <span class="nav-home-icon">🏛️</span>
            <span class="nav-title">Zurück zur Übersicht</span>
          </a>

          {
            nextStation && (
              <a href={nextStation.path} class="nav-btn nav-next">
                <span class="nav-direction">Nächste Station →</span>
                <span class="nav-title">
                  {nextStation.title.replace(
                    `Station ${nextStation.stationNumber}: `,
                    "",
                  )}
                </span>
              </a>
            )
          }
        </div>
      </nav>
    </div>
  </main>
</Layout>

---
import Layout from "../components/Layout.astro";
import "../styles/global.css";
import { agoraStations } from "../routes/router.ts";
---

<Layout
  title="Agora Audioführung | Antikes Griechenland"
  description="Entdecke die antike Agora von Athen mit unserer interaktiven Audioführung. 15 Stationen führen dich durch die Geschichte des politischen und wirtschaftlichen Zentrums des antiken Griechenlands."
>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <!-- Main Title Block -->
        <div class="hero-main">
          <div class="hero-badge">📚 Bildungsprojekt</div>
          <h1 class="hero-title">Agora Audioführung</h1>
          <h2 class="hero-subtitle">Antikes Griechenland</h2>
        </div>

        <!-- Description & CTA -->
        <div class="hero-description">
          <p>
            Entdecke die Wiege der Demokratie durch eine immersive Audioführung.
            15 authentische Stationen führen dich durch das politische und
            kulturelle Herz des antiken Athens.
          </p>

          <!-- Important Notice -->
          <div class="important-note">
            <div class="accent-bar"></div>
            <p>
              Interaktive Zeitreise in die Antike – Perfekt für
              Geschichtsbegeisterte und Schüler
            </p>
          </div>

          <!-- Quick Stats -->
          <div class="quick-stats">
            <div class="stat">
              <span class="stat-number">15</span>
              <span class="stat-label">Stationen</span>
            </div>
            <div class="stat">
              <span class="stat-number" id="total-duration-minutes">--</span>
              <span class="stat-label">Minuten</span>
            </div>
            <div class="stat">
              <span class="stat-number">100%</span>
              <span class="stat-label">Self-made</span>
            </div>
          </div>

          <!-- Main CTA -->
          <div class="cta-section">
            <a href="/station-1" class="cta-primary">
              <span class="cta-icon">▶</span>
              <span class="cta-text">Tour jetzt starten</span>
            </a>
            <a
              href="/agora_handout.pdf"
              class="cta-secondary download-btn"
              download="agora_handout.pdf"
            >
              <span class="cta-icon">⬇️ </span>
              <span class="cta-text"> Handout herunterladen</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Educational Info -->
  <section class="info-section">
    <div class="container">
      <!-- Educational Box -->
      <div class="info-box">
        <h3>📖 Bildungsinhalt</h3>
        <p>
          Diese Audioführung vermittelt historisch authentisches Wissen über die
          antike griechische Agora und wurde speziell für Bildungszwecke
          entwickelt.
        </p>
      </div>
    </div>
  </section>

  <!-- Stations Grid -->
  <section id="stationen" class="stations-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Audio-Stationen</h2>

        <!-- Navigation Hint -->
        <div class="navigation-hint">
          <div class="accent-bar"></div>
          <p>Folge der chronologischen Reihenfolge für die beste Erfahrung</p>
        </div>
      </div>

      <div class="stations-grid">
        {
          agoraStations.map((station) => (
            <a href={station.path} class="station-card">
              <div class="station-header">
                <div class="station-number">{station.stationNumber}</div>
                <div
                  class="station-duration"
                  data-audio-src={station.audioFile}
                >
                  ~--:-- Min
                </div>
              </div>
              <h3 class="station-name">
                {station.title.replace(
                  `Station ${station.stationNumber}: `,
                  "",
                )}
              </h3>
              <p class="station-description">{station.shortDescription}</p>
              <div class="station-action">Anhören →</div>
            </a>
          ))
        }
      </div>

      <!-- Quick Start Guide -->
      <div class="quick-guide">
        <h3>🚀 Schnellstart</h3>
        <p>
          Beginne mit <strong>Station 1</strong> und folge der chronologischen Reihenfolge.
          Jede Station enthält ein 3-4 minütiges Audio und detaillierte historische
          Informationen.
        </p>
        <div class="guide-actions">
          <a href="/station-1" class="guide-btn primary">▶ Jetzt beginnen</a>
          <a href="#stationen" class="guide-btn secondary">Übersicht</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Audio-Dauern und Gesamtdauer dynamisch laden
  document.addEventListener("DOMContentLoaded", function () {
    const durationElements = Array.from(document.querySelectorAll(
      ".station-duration[data-audio-src]",
    ));
    const totalDurationElement = document.getElementById("total-duration-minutes");
    let totalDurationSeconds = 0;

    const resolveAudioSrc = (audioSrc) => {
      try {
        return new URL(audioSrc, window.location.origin).toString();
      } catch {
        return audioSrc;
      }
    };

    const loadDuration = async (element) => {
      const audioSrc = element.getAttribute("data-audio-src");

      try {
        if (!audioSrc) {
          throw new Error("Audio-Quelle fehlt");
        }

        const audio = new Audio(resolveAudioSrc(audioSrc));

        await new Promise((resolve, reject) => {
          const timeoutId = window.setTimeout(() => {
            reject(new Error("Timeout beim Laden der Audio-Metadaten"));
          }, 30000);

          const cleanup = () => {
            window.clearTimeout(timeoutId);
            audio.removeEventListener("loadedmetadata", onLoad);
            audio.removeEventListener("durationchange", onLoad);
            audio.removeEventListener("loadeddata", onLoad);
            audio.removeEventListener("canplay", onLoad);
            audio.removeEventListener("error", onError);
          };

          const onLoad = () => {
            cleanup();
            resolve(undefined);
          };

          const onError = () => {
            cleanup();
            reject(new Error("Audio-Metadaten konnten nicht geladen werden"));
          };

          audio.addEventListener("loadedmetadata", onLoad);
          audio.addEventListener("durationchange", onLoad);
          audio.addEventListener("loadeddata", onLoad);
          audio.addEventListener("canplay", onLoad);
          audio.addEventListener("error", onError);
          audio.preload = "metadata";
          if (audio.readyState >= 1) {
            onLoad();
          }
        });

        const duration = audio.duration;

        if (!Number.isFinite(duration) || duration <= 0) {
          throw new Error("Ungültige Audio-Dauer");
        }

        const minutes = Math.floor(duration / 60);
        const seconds = Math.floor(duration % 60);
        const formattedDuration = `${minutes}:${seconds.toString().padStart(2, "0")} Min`;

        element.textContent = formattedDuration;
        totalDurationSeconds += duration;
      } catch (error) {
        element.textContent = "--:-- Min";
        console.warn(`Konnte Audio-Dauer für ${audioSrc} nicht laden:`, error);
      }
    };

    const queue = [...durationElements];
    const workers = Array.from({ length: Math.min(3, queue.length) }, async () => {
      while (queue.length > 0) {
        const element = queue.shift();
        if (element) {
          await loadDuration(element);
        }
      }
    });

    Promise.all(workers).then(() => {
      if (!totalDurationElement) {
        return;
      }

      if (totalDurationSeconds > 0) {
        totalDurationElement.textContent = String(
          Math.round(totalDurationSeconds / 60),
        );
        return;
      }

      totalDurationElement.textContent = "--";
    });
  });
</script>
